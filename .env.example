# ============================================================
# Demóstenes — variáveis de ambiente
# ============================================================
# A chave é lida SOMENTE server-side pela API route /api/analyze.
# Defina como `GEMINI_API_KEY` (SEM prefixo VITE_) na Vercel:
#   Settings → Environment Variables → Add → Key: GEMINI_API_KEY
#
# Obtenha sua chave em: https://aistudio.google.com/apikey
# ============================================================

GEMINI_API_KEY=sua_chave_aqui
